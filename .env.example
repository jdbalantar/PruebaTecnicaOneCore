# ============================================================
# PruebaTecnica — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to source control.
# ============================================================

# ---- App ----
APP_NAME=PruebaTecnica
APP_ENV=development
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-strong-random-secret

# ---- JWT RS256 ----
JWT_ALGORITHM=RS256
# PEM-encoded RSA private key (single line with \n as literal newline escapes, or multi-line)
# Generate with: openssl genrsa -out private.pem 2048
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n<base64-encoded-key>\n-----END RSA PRIVATE KEY-----"
# Corresponding public key
# Generate with: openssl rsa -in private.pem -pubout -out public.pem
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n<base64-encoded-key>\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# ---- SQL Server ----
DB_HOST=localhost
DB_PORT=1433
DB_NAME=prueba_tecnica
DB_USER=sa
DB_PASSWORD=YourStrong!Passw0rd
DB_DRIVER=ODBC Driver 17 for SQL Server

# ---- AWS S3 ----
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_CSV=onecore-uploads
S3_BUCKET_DOCS=onecore-documents

# ---- Storage Provider Selection ----
STORAGE_DEFAULT_PROVIDER=minio

# MinIO (S3 compatible)
MINIO_ENDPOINT_URL=http://localhost:9000
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_ACCESS_KEY=minioadmin
MINIO_BUCKET_CSV=onecore-uploads
MINIO_BUCKET_DOCS=onecore-documents

# LocalStack S3 (S3 compatible)
LOCALSTACK_ENDPOINT_URL=http://localhost:4566
LOCALSTACK_ACCESS_KEY_ID=test
LOCALSTACK_SECRET_ACCESS_KEY=test
LOCALSTACK_BUCKET_CSV=onecore-uploads-localstack
LOCALSTACK_BUCKET_DOCS=onecore-documents-localstack

# ---- AI Provider ----
AI_PROVIDER=gemini

# ---- Gemini ----
GEMINI_API_KEY=
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL_CLASSIFY=gemini-2.5-flash-lite
GEMINI_MODEL_EXTRACT=gemini-2.5-flash-lite

# ---- CSV Validation ----
CSV_MAX_FILE_SIZE_MB=10
CSV_MAX_ROWS=50000
